<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"> <LinearLayout
    android:id="@+id/headerRiwayat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface" android:padding="16dp"
    android:elevation="4dp"
    app:layout_constraintTop_toTopOf="parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvRiwayatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riwayat Transaksi"
            android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <ImageButton
            android:id="@+id/btnDownloadPdf"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            app:tint="#2980B9"
            android:contentDescription="Download PDF" />
    </RelativeLayout>

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:alpha="0.8"
        android:hint="Cari pembeli atau barang..."
        android:background="@drawable/bg_edittext_rounded"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" android:inputType="text"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnPickDate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Tanggal"
            android:textSize="12sp"
            app:icon="@android:drawable/ic_menu_today"/>

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Semua Waktu"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp"/>

        <ImageButton
            android:id="@+id/btnResetFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#E74C3C"
            android:visibility="gone"
            android:contentDescription="Reset Filter" />
    </LinearLayout>

</LinearLayout>

    <ListView
        android:id="@+id/lvRiwayat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:divider="#8094A3B8"
        android:dividerHeight="1.5dp"
        android:headerDividersEnabled="false"
        android:footerDividersEnabled="false"
        app:layout_constraintTop_toBottomOf="@id/headerRiwayat"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>